{
    "compilerOptions": {
        "strict": true,
        "allowJs": true,
        "module": "NodeNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "target": "ESNext",
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "~/*": ["./src/*"]
        }
    }
}
